# Database — paste Neon connection string here (or link from Vercel)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Session secret — generate with: openssl rand -base64 32
SESSION_PASSWORD=replace-with-32-byte-random-secret-string

# Vercel Blob — auto-injected by Vercel when you enable the integration
BLOB_READ_WRITE_TOKEN=
